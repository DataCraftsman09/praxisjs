{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "jsxImportSource": "@verbose/jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./src/ui/shared/*"],
      "@assets/*": ["./assets/*"],
      "@core/*": ["./src/core/*"],
      "@plugins/*": ["./src/plugins/*"],
      "@decorators/*": ["./src/decorators/*"],
      "@utils/*": ["./src/utils/*"],
      "@icons": ["./src/icons/index.ts"]
    }
  },
  "include": ["src", "uno.config.ts", "vite.config.ts"]
}
